module ram(
    input clk,
    input write_enable,
    input enable,
    input [3:0] addr,
    input [7:0] data_in,
    output reg [7:0] data_out
);

    reg [7:0] mem [15:0];

    always @(posedge clk)
    begin
        // Write Operation
        if(write_enable && !enable)
            mem[addr] <= data_in;

        // Read Operation
        if(enable && !write_enable)
            data_out <= mem[addr];
    end

endmodule
